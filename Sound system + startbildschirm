def update(dt):
    global restzeit, gewonnen, verloren, level, zustand
    global wettertimer, wetter, aktueller_sound
    global startmusik_spielt
    global intro_timer, sound_gestartet
     
    if zustand == "intro": 
        if not sound_gestartet:
            sounds.start.play()
            sound_gestartet = True
            
        intro_timer -= dt
        
        if intro_timer <= 0:
            zustand ="start"
        return        
    
    if zustand == "start":
        if keyboard.a:
            zustand = "spiel"
            
        return           
                   
    if zustand == "spiel":
        bewegung(dt)

    # Wettertimer
    wettertimer += dt

    if wettertimer >= WETTERINTERVALL:
        wettertimer = 0
        wetter = random.choice(["sonne", "regen"])

    if zustand == "start":
        if keyboard.a:
            sounds.start.stop()
            zustand = "spiel"
        return

    if zustand == "uebergang":

        if keyboard.a:
            zustand = "spiel"

        return

    if zustand == "ende":

        if keyboard.d:
            neustart()

        return

    shop()

    restzeit -= dt
    
     # Regen beeinflusst Wasser
    if wetter == "regen":
        
            
        if aktueller_sound != "regen":
            sounds.vogel.stop()
            sounds.regen.play()
            aktueller_sound = "regen"
            
        elif wetter == "sonne":
            if aktueller_sound != "vogel":
                sounds.regen.stop()
                sounds.vogel.play()
                
                aktueller_sound = "vogel"

    for beet in BEET:

        # Regen beeinflusst Wasser
        if wetter == "regen":
            beet.wasser += 0.2 * dt
            
            if aktueller_sound != "regen":
                
                sounds.vogel.stop()
                sounds.regen.play(-1)
                
                aktueller_sound = "regen"
            beet.wasser += 0.2 * dt
        elif wetter == "sonne":
            if aktueller_sound != "vogel":
                sounds.regen.stop()
                sounds.vogel.play(-1)
                aktueller_sound = "vogel"
            
        # Pflanzenwachstumssystem
        if beet.bepflanzt:

            if beet.wasser > 0:
                beet.wachstum += WACHSTUM[beet.pflanze] * dt
                beet.wasser -= 0.3 * dt

            elif beet.wasser <= 0:
                beet.wachstum -= 5 * dt

            # Pflanze wird reif
            if beet.wachstum >= 100:
                beet.wachstum = 100
                beet.pflanzenbild.image = PFLANZENREIF[beet.pflanze]

    # Level abgeschlossen
    if geld >= levelziel and not gewonnen:

        gewonnen = True

        if level < 3:
            uebergang()

        else:
            zustand = "ende"

    # Zeit abgelaufen
    if restzeit <= 0 and geld < levelziel:

        verloren = True
        neustart()

pgzrun.go()

