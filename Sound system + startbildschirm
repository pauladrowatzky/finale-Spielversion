hase = Actor("hase_rechts_1")
hase.x = 700
hase.y = 400

hasen_richtung = 1
hasen_timer = 0
hasen_speed = 70

def bewegung(dt):
    global hasen_timer
    global hasen_richtung

    # Bewegung
    hase.x += hasen_speed * hasen_richtung * dt

    # Richtungswechsel
    if hase.right >= WIDTH:
        hasen_richtung = -1

    elif hase.left <= 0:
        hasen_richtung = 1

    # Animationstimer
    hasen_timer += dt

    if hasen_timer >= 0.25:

        # RECHTS
        if hasen_richtung == 1:

            if hase.image == "hase_rechts_1":
                hase.image = "hase_rechts_2"
            else:
                hase.image = "hase_rechts_1"

        # LINKS
        else:

            if hase.image == "hase_links_1":
                hase.image = "hase_links_2"
            else:
                hase.image = "hase_links_1"

        hasen_timer = 0

