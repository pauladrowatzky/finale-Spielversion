hasen_speed = 45
HASEN_MIN_X = 250
HASEN_MAX_X = 800

# Funktion für Hasenbewegung
def bewegung(dt):
    global hasen_timer
    global hasen_richtung

    # Bewegung
    hase.x += hasen_speed * hasen_richtung * dt

    # Richtungswechsel
    if hase.right >= HASEN_MAX_X:
        hasen_richtung = -1

    elif hase.left <= HASEN_MIN_X:
        hasen_richtung = 1

    # Animationstimer
    hasen_timer += dt

    if hasen_timer >= 0.25:

        # RECHTS
        if hasen_richtung == 1:

            if hase.image == "hase_rechts_1":
                hase.image = "hase_rechts_2"
            else:
                hase.image = "hase_rechts_1"

        # LINKS
        else:

            if hase.image == "hase_links_1":
                hase.image = "hase_links_2"
            else:
                hase.image = "hase_links_1"

        hasen_timer = 0
