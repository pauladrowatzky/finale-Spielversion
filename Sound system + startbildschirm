# Shop für Pflanzen
def shop():
    global gewaehltepflanze

    if keyboard.s:

        if keyboard.k_1:
            gewaehltepflanze = "salat"

        elif keyboard.k_2:
            gewaehltepflanze = "sonnenblume"

        elif keyboard.k_3:
            gewaehltepflanze = "radieschen"

        elif keyboard.k_4:
            gewaehltepflanze = "kuerbis"

# Funktion für Klicken
def on_mouse_down(pos):
    global geld
    global salat_geerntet
    global sonnenblume_geerntet

    if zustand != "spiel":
        return

    for beet in BEET:

        if beet.collidepoint(pos):

            # ernten
            if beet.bepflanzt and beet.wachstum >= 100:
                if beet.pflanze == "salat":
                    salat_geerntet += 1
                if beet.pflanze == "sonnenblume":
                    sonnenblume_geerntet += 1    

                geld += VERKAUFSPREISE[beet.pflanze]

                sounds.ernten.play()

                beet.bepflanzt = False
                beet.pflanze = ""
                beet.wachstum = 0
                beet.wasser = 0
                beet.pflanzenbild = None

            # gießen
            elif beet.bepflanzt and keyboard.w:

                beet.wasser = min(beet.wasser + 1, 5)

                sounds.giessen.play()

            # neu bepflanzt
            elif not beet.bepflanzt:

                preis = PFLANZENPREISE[gewaehltepflanze]

                if geld >= preis:

                    geld -= preis

                    beet.bepflanzt = True
                    beet.pflanze = gewaehltepflanze

                    beet.wachstum = 0
                    beet.wasser = 0

                    sounds.pflanzen.play()

                    beet.pflanzenbild = Actor(
                        PFLANZENBILDER[gewaehltepflanze]
                    )

                    beet.pflanzenbild.center = beet.actor.center

