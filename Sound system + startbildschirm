# Update- Funktion
def update(dt):
# globale Variablen
    global restzeit, gewonnen, verloren, level, zustand
    global wettertimer, wetter, aktueller_sound
    global startmusik_spielt
    global intro_timer, sound_gestartet
    # bei Zustand intro 
    if zustand == "intro": 
        if not sound_gestartet:
            sounds.start.play()
            sound_gestartet = True
        intro_timer -= dt
        
        if intro_timer <= 0:
            zustand ="start"
        return        
    # bei Zustand Start
    if zustand == "start":
        if keyboard.a:
            zustand = "spiel"
        return           
   # bei Zustand Spiel                
    if zustand == "spiel":
        # Unterscheidung Regen vs. Sonne
        if wetter == "regen":
            if aktueller_sound != "regen":
                sounds.vogel.stop()
                sounds.regen.play()
                aktueller_sound = "regen"

        elif wetter == "sonne":
            if aktueller_sound != "vogel":
                sounds.regen.stop()
                sounds.vogel.play()
                aktueller_sound = "vogel"
        # Bewegung Hase
        bewegung(dt)
    # bei Zustand gameover
    if zustand == "gameover":
        if keyboard.d:
            neustart()
        return

    # Wettertimer
    wettertimer += dt

    # Änderung Wetter
    if wettertimer >= WETTERINTERVALL:
        wettertimer = 0
        wetter = random.choice(["sonne", "regen"])

    # bei Zustand start
    if zustand == "start":
        if keyboard.a:
            sounds.start.stop()
            zustand = "spiel"
        return
    # bei Zustand Übergang
    if zustand == "uebergang":
        if keyboard.a:
            zustand = "spiel"
        return
    # bei Zustand ende
    if zustand == "ende":
        if keyboard.d:
            neustart()
        return
    # Shop-Funktion
    shop()

    #Restzeit korrigieren
    restzeit -= dt
    
     # Regen beeinflusst Wasser
    if wetter == "regen":
        
        if aktueller_sound != "regen":
            sounds.vogel.stop()
            sounds.regen.play()
            aktueller_sound = "regen"
            
    elif wetter == "sonne":
        if aktueller_sound != "vogel":
            sounds.regen.stop()
            sounds.vogel.play()
                
            aktueller_sound = "vogel"

    for beet in BEET:
    
        # Regen beeinflusst Wasser
        if wetter == "regen":
            beet.wasser = min(beet.wasser + 0.2 * dt, 5)
    
        # Pflanzenwachstumssystem
        if beet.bepflanzt:

            if beet.wasser > 0:
                beet.wachstum += WACHSTUM[beet.pflanze] * dt
                beet.wasser -= 0.3 * dt

            elif beet.wasser <= 0:
                beet.wachstum -= 5 * dt

            # Pflanze wird reif
            if beet.wachstum >= 100:
                beet.wachstum = 100
                beet.pflanzenbild.image = PFLANZENREIF[beet.pflanze]

    # Level abgeschlossen
    if not gewonnen:
        
        if level == 1 or level == 2:
            if geld>= levelziel:
                gewonnen = True
                uebergang()
        elif level == 3:
            if salat_geerntet >= 5 and sonnenblume_geerntet >= 3:
                gewonnen = True
                zustand = "ende"        

    # Zeit abgelaufen
    if restzeit <= 0 and geld < levelziel:
        gameover()

pgzrun.go()
